{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/cart",
      "destination": "/cart.html"
    },
    {
      "source": "/search",
      "destination": "/search.html"
    },
    {
      "source": "/product",
      "destination": "/product.html"
    },
    {
      "source": "/wishlist",
      "destination": "/wishlist.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/orders",
      "destination": "/orders.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/payment",
      "destination": "/payment.html"
    },
    {
      "source": "/notifications",
      "destination": "/notifications.html"
    },
    {
      "source": "/address",
      "destination": "/address.html"
    },
    {
      "source": "/order-summary",
      "destination": "/order-summary.html"
    },
    {
      "source": "/order-confirmation",
      "destination": "/order-confirmation.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/404.html",
      "status": 404
    }
  ]
}